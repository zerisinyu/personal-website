---
// Grid of images, side by side. Usage in .mdx:
//   <Gallery columns={2}>
//     ![alt](./a.png)
//     ![alt](./b.png)
//   </Gallery>
interface Props {
  columns?: number;
}

const { columns = 2 } = Astro.props;
---

<div class="gallery" style={`--cols: ${columns}`}>
  <slot />
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    gap: var(--space-2);
    margin-block: 2em;
  }

  .gallery :global(p) {
    margin: 0;
  }

  .gallery :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 40rem) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>
