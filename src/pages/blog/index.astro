---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url, formatDate } from '../../lib/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Blog">
  <h1 class="page-title">Blog</h1>

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <a href={url(`/blog/${post.id}`)}>
            <span class="post-title">{post.data.title}</span>
            <time class="small muted" datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
          </a>
          {post.data.summary && <p class="small muted">{post.data.summary}</p>}
        </li>
      ))
    }
  </ul>

  <p class="small muted subscribe">
    Subscribe via <a class="rss" href={url('/rss.xml')}>RSS</a>.
    <!-- Newsletter slot: swap in a Buttondown (or similar) form here later. -->
  </p>
</Base>

<style>
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: var(--width-prose);
  }

  .post-list li + li {
    margin-top: var(--space-3);
  }

  .post-list a {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    align-items: baseline;
  }

  .post-title {
    font-weight: 550;
  }

  .post-list a:hover .post-title {
    color: var(--color-accent);
  }

  .post-list p {
    margin: 0.2rem 0 0;
  }

  time {
    flex-shrink: 0;
  }

  .subscribe {
    margin-top: var(--space-5);
  }

  .rss {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .rss:hover {
    color: var(--color-accent);
  }
</style>
