---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Figure from '../../components/Figure.astro';
import Gallery from '../../components/Gallery.astro';
import TwoColumn from '../../components/TwoColumn.astro';
import FullBleed from '../../components/FullBleed.astro';
import Video from '../../components/Video.astro';
import { url } from '../../lib/site';

export async function getStaticPaths() {
  // Only case-study projects get an auto-rendered detail page; custom and
  // external projects link elsewhere from the index.
  const projects = await getCollection(
    'projects',
    ({ data }) => data.type === 'case-study' && !data.draft
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, summary, year, tags, cover, tools, links } = project.data;
const { Content } = await render(project);

// Layout components are available in .mdx bodies without imports.
const components = { Figure, Gallery, TwoColumn, FullBleed, Video };
---

<Base title={title} description={summary}>
  <article>
    <header class="project-header">
      <p class="crumb small muted">
        <a href={url('/work')}>Projects</a>
        <span aria-hidden="true"> / </span>
        {year}
      </p>
      <h1 class="display">{title}</h1>
      <p class="summary muted">{summary}</p>
      <dl class="facts small">
        {
          tags.length > 0 && (
            <div>
              <dt class="muted">Field</dt>
              <dd>{tags.join(', ')}</dd>
            </div>
          )
        }
        {
          tools.length > 0 && (
            <div>
              <dt class="muted">Tools</dt>
              <dd>{tools.join(', ')}</dd>
            </div>
          )
        }
        {
          links.length > 0 && (
            <div>
              <dt class="muted">Links</dt>
              <dd>
                {links.map((link, i) => (
                  <>
                    {i > 0 && ' · '}
                    <a
                      class="fact-link"
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {link.label} ↗
                    </a>
                  </>
                ))}
              </dd>
            </div>
          )
        }
      </dl>
    </header>

    {
      cover && (
        <Image
          class="cover"
          src={cover}
          alt=""
          widths={[800, 1200, 1800]}
          sizes="(max-width: 72rem) 100vw, 72rem"
        />
      )
    }

    <div class="prose">
      <Content components={components} />
    </div>
  </article>
</Base>

<style>
  .project-header {
    max-width: var(--width-prose);
    margin: var(--space-3) auto var(--space-5);
  }

  .crumb {
    margin: 0 0 var(--space-2);
  }

  .crumb a:hover {
    color: var(--color-accent);
  }

  h1 {
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    margin: 0 0 var(--space-2);
  }

  .summary {
    font-size: var(--text-md);
    font-weight: 350;
    max-width: 40rem;
    margin: 0 0 var(--space-3);
  }

  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1) var(--space-4);
    margin: 0;
    font-weight: 350;
  }

  .facts div {
    display: flex;
    gap: 0.5rem;
  }

  .facts dt {
    margin: 0;
  }

  .facts dd {
    margin: 0;
  }

  .fact-link {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .fact-link:hover {
    color: var(--color-accent);
  }

  .cover {
    width: 100%;
    height: auto;
    margin-bottom: var(--space-5);
  }
</style>
